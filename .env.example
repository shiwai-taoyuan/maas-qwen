# 模式与基础服务
MODE=prd
SERVER_NAME=0.0.0.0
PORT=9001
UVICORN_LOG_LEVEL=info

# 模型相关
QWEN2_MODEL_DIR=/checkpoints/Qwen2.5-72B-Instruct
TORCH_DTYPE=bfloat16
SKIP_MODEL_INITIALIZATION=0

# API 并发控制
API_MAX_CONCURRENCY=4
API_ACQUIRE_TIMEOUT_SECONDS=30
PLUGIN_REFRESH_INTERVAL_SECONDS=30

# 上传与文档
MAX_UPLOAD_SIZE_MB=50
ENABLE_DOCS=1

# vLLM 参数
VLLM_TENSOR_PARALLEL_SIZE=2
VLLM_GPU_MEMORY_UTILIZATION=0.98
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_SEQ_LEN_TO_CAPTURE=8192
